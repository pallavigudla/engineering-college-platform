# ============================================================
# ENVIRONMENT VARIABLES - Copy this to .env and fill values
# ============================================================

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-here

# Neon PostgreSQL Connection URL
# Format: postgresql://username:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-1.aws.neon.tech/college_db?sslmode=require

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=0

# Admin credentials (used during initial setup)
ADMIN_EMAIL=admin@collegeplatform.com
ADMIN_PASSWORD=SecureAdminPass123!

# WTForms CSRF
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600

# Session
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Upload settings
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads
